# =============================================================================
# Kasi — Template de variables d'environnement
# Copier ce fichier en .env et renseigner chaque valeur CHANGEME.
# Ce fichier est versionne (documentation) ; .env est ignore par git.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de donnees PostgreSQL + PostGIS
# En dev local sans Docker : DB_HOST=localhost
# Dans le reseau Docker Compose : DB_HOST=postgres (nom du service)
# -----------------------------------------------------------------------------
DB_NAME=kasi_database
DB_USER=postgres
DB_PASS=CHANGEME_kasi
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# En dev local sans Docker : REDIS_HOST=localhost
# Dans le reseau Docker Compose : REDIS_HOST=redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME

# -----------------------------------------------------------------------------
# JWT — minimum 32 caracteres, generer via : openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=781196fcb8359bf6588dd08af2285ac283e1a0aa9f9b85ddaa10daffdac4b6eb

# -----------------------------------------------------------------------------
# Firebase Admin SDK
# Laisser vide si Firebase n est pas active (a valider par kasi-integrations-auditor).
# Ne jamais committer les valeurs reelles — passer par un gestionnaire de secrets.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Fournisseur geographique
# GEO_PROVIDER=google   -> utilise Google Maps (necessite GOOGLE_MAPS_API_KEY)
# GEO_PROVIDER=nominatim -> utilise Nominatim/OSM (open-source, sans cle)
# -----------------------------------------------------------------------------
GEO_PROVIDER=google
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# CORS — origines autorisees par les APIs NestJS
# En production, Nginx gere les headers CORS en amont ; cette variable
# restreint les origines acceptees directement par NestJS (defense en profondeur).
# Valeurs multiples separees par des virgules, sans espaces.
# Laisser vide pour utiliser les defauts de developpement local.
# -----------------------------------------------------------------------------
# CORS_ORIGIN=https://admin.kasi.app

# -----------------------------------------------------------------------------
# Registre d'images Docker (utilise par docker-compose.yml pour `image:`)
# En dev local : laisser vide, `docker compose up --build` construit et tague
# les images localement (defaut kasi-local), aucun pull necessaire.
# Sur le serveur de production (/opt/kasi/.env) : renseigner IMAGE_REGISTRY avec
# la meme valeur que les tags pousses par deploy.yml, soit
# ghcr.io/<owner>/<repo> (ex: ghcr.io/ZayTauven/kasi) — necessaire pour que
# `docker compose pull` recupere les images buildees par CI/CD.
# -----------------------------------------------------------------------------
IMAGE_REGISTRY=
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Mapbox GL JS — token public (pk.xxx) utilise par l'admin-panel pour l'affichage
# des cartes (voir KASI_DECISIONS.md, 2026-07-01 "migration Google Maps -> Mapbox").
# Injecte au build Docker via l'ARG MAPBOX_TOKEN (docker-compose.yml, apps/admin-panel/Dockerfile)
# dans src/environments/environment.prod.ts — jamais committe en dur dans le code source.
# Sans valeur : le build reussit quand meme, seules les cartes restent vides.
# -----------------------------------------------------------------------------
MAPBOX_TOKEN=
