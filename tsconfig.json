{
   "compilerOptions": {
      "lib": [
         "es5",
         "es6"
      ],
      "target": "es5",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "strict": false,
      "noUncheckedSideEffectImports": false,
      "types": [
        "*"
      ],
      "esModuleInterop": false,
      "ignoreDeprecations": "6.0"
   }
}