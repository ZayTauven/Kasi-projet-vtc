{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": [
      "node"
    ],
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "incremental": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "**/*.spec.ts",
    "jest.config.ts"
  ],
  "include": [
    "**/*.ts"
  ],
  "angularCompilerOptions": {
    "strictTemplates": false
  }
}
